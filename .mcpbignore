# Source/tests — only dist/ + node_modules run at runtime.
# IMPORTANT: patterns are gitignore-style — WITHOUT a leading slash they match
# at ANY depth, including inside node_modules (an unanchored `src/` once
# stripped node_modules/debug/src and broke the bundle). Keep them anchored.
/src/
/scripts/
/README.md
/UPSTREAM_README.md
/UPSTREAM_CHANGELOG.md
/STYLE_GUIDE.md
/tsconfig.json
/eslint.config.mjs
/.prettierrc
/.env.example
/.node-version
/package-lock.json

# Never ship local secrets or dev artifacts
/.env
/coverage/
/*.tgz

# Build outputs / scratch
*.mcpb
